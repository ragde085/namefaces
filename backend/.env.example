# Copy to .env and adjust. Dev defaults to SQLite (no Postgres needed).

# Dev (SQLite):
DATABASE_URL=sqlite:///./namefaces.db
# Prod (GCP Cloud SQL Postgres):
# DATABASE_URL=postgresql+psycopg://user:pass@host:5432/namefaces

# Comma-separated allowed CORS origins (Vite dev server default below).
CORS_ORIGINS=http://localhost:5173

# Quiz defaults (admin-configurable).
QUIZ_LENGTH=8
TIMER_SECONDS=15

# Auth — Google Workspace OIDC (TODO: wire real verification).
GOOGLE_CLIENT_ID=
GOOGLE_HOSTED_DOMAIN=griddynamics.com
# Comma-separated admin emails (until group-based roles are wired).
ADMIN_EMAILS=

# Seed demo employees on startup (dev only).
SEED_ON_STARTUP=true
